# novaFit Backend — Environment Variables
# Copy this to .env and fill in your keys

# ─────────────────────────────────────────
# AI PROVIDERS (all free tiers)
# ─────────────────────────────────────────

# 1. Groq — fastest, highly recommended
#    Get key: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. NVIDIA NIM — OpenAI-compatible, 100+ models
#    Get key: https://build.nvidia.com → Get API Key
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 3. OpenRouter — multi-model router, 50+ free models
#    Get key: https://openrouter.ai → Keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 4. Hugging Face — last-resort fallback
#    Get key: https://huggingface.co/settings/tokens → New Token (Read)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────
# FOOD DATABASE (free)
# ─────────────────────────────────────────

# USDA FoodData Central API (free, 1000 req/hr)
#    Get key: https://fdc.nal.usda.gov/api-key-signup
USDA_KEY=DEMO_KEY

# ─────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# ─────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────
PORT=3000
NODE_ENV=development
